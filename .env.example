# ───────────────────────────────────────
# Aetherius — Backend Environment Variables
# ───────────────────────────────────────
# Copy this to .env and fill in your values

# ── PostgreSQL ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=aetherius
DB_PASSWORD=password

# ── JWT ───────────────────────────────
JWT_ACCESS_KEY=change-this-to-a-random-64-char-string
JWT_REFRESH_KEY=change-this-to-a-different-random-64-char-string
JWT_ISSUER=aetherius

# ── RabbitMQ ─────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── Redis ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO (Object Storage) ───────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=aetherius
MINIO_SECRET_KEY=password

# ── Email (SendGrid / SES) ───────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@aetherius.io

# ── OAuth ────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── Node Agent ────────────────────────
AETHERIUS_SERVER_URL=http://localhost:8080
AETHERIUS_PROVIDER_ID=get-this-from-your-dashboard
AETHERIUS_AGENT_VERSION=0.1.0

# ── Observability ────────────────────
PROMETHEUS_PUSH_GATEWAY=http://localhost:9091
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
